# Project Development Commands
# ----------------------------------

# Define common variables
docker_compose := "docker compose"
project := "{{cookiecutter.project_slug}}"

# Set default recipe to list commands
default:
    @just --list

# Derive PROJECT name from current git branch (used as inline env var for docker compose).
# main → {{cookiecutter.project_slug}}-main
# feature/my-thing → {{cookiecutter.project_slug}}-my-thing
[private]
_project:
    #!/usr/bin/env bash
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
    if [ "$branch" = "main" ]; then
      echo "{{cookiecutter.project_slug}}-main"
    else
      stripped=$(echo "$branch" | sed 's|^[a-zA-Z][a-zA-Z0-9]*[/_]||')
      echo "{{cookiecutter.project_slug}}-$(echo "$stripped" | tr '[:upper:]' '[:lower:]' | tr '/_' '-' | sed 's/[^a-z0-9-]//g')"
    fi

