# Project Development Commands
# ----------------------------------

# Define common variables
docker_compose := "docker compose"
project := "{{cookiecutter.project_slug}}"

# Set default recipe to list commands
default:
    @just --list

# Client commands
[group('client')]
client-serve:
    cd client && npm run serve
    @echo "🚀 Client ready at localhost"

[group('client')]
client-build:
    cd client && npm run build

[group('client')]
client-lint:
    cd client && npm run eslint && npm run tslint

[group('client')]
client-format:
    cd client && npm run format:write

[group('client')]
client-test:
    cd client && npm run test

[group('client')]
client-test-single TESTPATH:
    cd client && npm run test:single {{ "{{TESTPATH}}" }}

[group('client')]
client-test-e2e:
    cd client && npm run test:e2e

# Server commands
[group('server')]
server-run:
    ./server/runserver.sh
    @echo "🚀 Backend ready at http://localhost:8000"

[group('server')]
server-test: django-check-migrations
    cd server && uv run python -m pytest --mccabe --cov={{ "{{ project }}" }} --cov-config=pyproject.toml -vv {{ "{{ project }}" }} && coverage report

[group('server')]
server-format:
    uv run ruff format server

[group('server')]
server-lint:
    uv run ruff check --fix server

[group('server')]
server-legacy-format:
    uv run black server && uv run isort server

# Docker commands
[group('docker')]
docker-stop-all:
    docker stop $(docker ps -q)

[group('docker')]
docker-postgres-redis:
    {{ "{{ docker_compose }}" }} up -d postgres redis

[group('docker')]
docker-run-all:
    {{ "{{ docker_compose }}" }} up -d

[group('docker')]
docker-restart-all:
    {{ "{{ docker_compose }}" }} down
    {{ "{{ docker_compose }}" }} up -d

[group('docker')]
docker-logs:
    {{ "{{ docker_compose }}" }} logs -f

[group('docker')]
docker-create-test-data:
	docker compose run server python server/manage.py create_test_data

# Django commands
[group('django')]
create-test-data:
    cd server && python manage.py create_test_data

[group('django')]
django-makemigrations name="":
    cd server && python manage.py makemigrations {{ "{{ name }}" }}

[group('django')]
django-migrate:
    cd server && python manage.py migrate

[group('django')]
django-check-migrations:
    cd server && python manage.py makemigrations --check --dry-run

[group('django')]
django-shell:
    cd server && python manage.py shell_plus

[group('django')]
django-runserver:
    cd server && python manage.py runserver 0.0.0.0:8000
    @echo "🚀 Backend ready at http://localhost:8000"

# Combined commands
[group('all')]
format: server-format client-format
    @echo "✅ All formatting complete"

[group('all')]
lint: server-lint client-lint
    @echo "✅ All linting complete"

[group('all')]
test: server-test client-test
    @echo "✅ All tests complete"

# Project setup
[group('setup')]
setup-dev: docker-postgres-redis django-migrate create-test-data
    @echo "✅ Development environment ready"

# Screenshot commands - App Store compliant dimensions
# Usage: just screenshots-resize <device> <input_dir> [output_dir]
# Devices: iphone-67, iphone-65, ipad-11, ipad-129, watch
[group('screenshots')]
screenshots-resize device input_dir output_dir="":
    #!/usr/bin/env bash
    set -euo pipefail

    case "{{ "{{ device }}" }}" in
        iphone-67)
            width=1284; height=2778
            desc="iPhone 6.7\" (Pro Max)"
            ;;
        iphone-65)
            width=1242; height=2688
            desc="iPhone 6.5\" (XS Max)"
            ;;
        ipad-11)
            width=2064; height=2752
            desc="iPad Pro 11\" (4th gen+)"
            ;;
        ipad-129)
            width=2048; height=2732
            desc="iPad Pro 12.9\""
            ;;
        watch)
            width=396; height=484
            desc="Apple Watch (45mm)"
            ;;
        *)
            echo "Unknown device: {{ "{{ device }}" }}"
            echo "Valid options: iphone-67, iphone-65, ipad-11, ipad-129, watch"
            exit 1
            ;;
    esac

    if [ -z "{{ "{{ output_dir }}" }}" ]; then
        outdir="{{ "{{ input_dir }}" }}/{{ "{{ device }}" }}"
    else
        outdir="{{ "{{ output_dir }}" }}/{{ "{{ device }}" }}"
    fi
    mkdir -p "$outdir"

    for file in "{{ "{{ input_dir }}" }}"/*.png; do
        [ -f "$file" ] || continue
        filename=$(basename "$file")
        sips -z "$height" "$width" "$file" --out "$outdir/$filename" 2>/dev/null
        echo "✓ $filename -> ${width}x${height}"
    done
    echo "✅ $desc screenshots saved to $outdir"

# Resize all device types at once from a single source
[group('screenshots')]
screenshots-resize-all input_dir output_dir="":
    #!/usr/bin/env bash
    if [ -z "{{ "{{ output_dir }}" }}" ]; then
        just screenshots-resize iphone-67 "{{ "{{ input_dir }}" }}"
        just screenshots-resize iphone-65 "{{ "{{ input_dir }}" }}"
        just screenshots-resize ipad-11 "{{ "{{ input_dir }}" }}"
        just screenshots-resize ipad-129 "{{ "{{ input_dir }}" }}"
    else
        just screenshots-resize iphone-67 "{{ "{{ input_dir }}" }}" "{{ "{{ output_dir }}" }}"
        just screenshots-resize iphone-65 "{{ "{{ input_dir }}" }}" "{{ "{{ output_dir }}" }}"
        just screenshots-resize ipad-11 "{{ "{{ input_dir }}" }}" "{{ "{{ output_dir }}" }}"
        just screenshots-resize ipad-129 "{{ "{{ input_dir }}" }}" "{{ "{{ output_dir }}" }}"
    fi
    echo "✅ All screenshots resized"