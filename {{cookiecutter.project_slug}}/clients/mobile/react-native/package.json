{
  "name": "{{ cookiecutter.project_slug }}",
  "version": "0.1.0",
  "private": true,
  "description": "App",
  "author": "Thinknmimble",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npm run start:nc",
    "start:nc": "expo start -c --go",
    "start:prod": "expo start --no-dev --minify",
    "start:android": "expo start --android",
    "start:ios": "expo start --ios",
    "start:web": "expo start --web",
    "prebuild": "npx expo prebuild",
    "run:android": "expo run:android",
    "run:android:release": "expo run:android --variant release",
    "run:ios": "expo run:ios",
    "run:ios:release": "expo run:ios --configuration Release",
    "prebuild:local": "source .env && SENTRY_PROJECT=${SENTRY_PROJECT_NAME} SENTRY_AUTH_TOKEN=${SENTRY_AUTH_TOKEN} expo prebuild",
    "pub:web": "npx expo export:web && cd web-build && vercel --prod && cd ..",
    "format:check": "prettier --check ./src",
    "format:write": "prettier --write ./src",
    "lint:tslint": "tsc --skipLibCheck",
    "lint:eslint": "eslint --ext .js,.ts,.jsx,.tsx --max-warnings=0 src",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
